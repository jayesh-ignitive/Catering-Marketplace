PORT=4000

# Image storage: `local` (default) writes under ./storage/public and serves `/uploads/…`; `r2` uses Cloudflare R2 (S3 API).
# IMAGE_STORAGE_DRIVER=local

# Base URL of this API — used for local driver URLs (`{UPLOAD_PUBLIC_BASE_URL}/uploads/...`)
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000

# Optional: absolute path where uploaded files are written (default: ./storage/public)
# UPLOAD_DISK_ROOT=C:\\path\\to\\catering-backend\\storage\\public

# --- Cloudflare R2 (S3-compatible) — only when IMAGE_STORAGE_DRIVER=r2 or s3 ---
# S3 endpoint from R2 dashboard (jurisdiction-specific), no trailing slash
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=caterersspace
# Public HTTPS origin where objects are readable (R2 custom domain or enabled r2.dev URL). No trailing slash. Must match bucket public access in Cloudflare.
# S3_PUBLIC_BASE_URL=https://images.example.com
# Optional: Cloudflare API token (dashboard/Workers); not used by Nest uploads — keep for scripts/automation only
# CLOUDFLARE_API_TOKEN=

# Public URL of the Next.js app (OTP links, legal placeholders)
APP_PUBLIC_URL=http://localhost:3000
# Production: APP_PUBLIC_URL=https://bharatcaterhub.com
# Staging: APP_PUBLIC_URL=https://staging.bharatcaterhub.com
SITE_URL=http://localhost:3000
SITE_NAME=Bharat Cater Hub
SUBDOMAIN_PARENT_DOMAIN=bharatcaterhub.com

# Brevo Transactional Email API (OTP, verification). Brevo → SMTP & API → API keys → xkeysib-…
# MAIL_FROM must be a verified sender in Brevo (Senders & Domains).
# MAIL_ENABLED=false logs email to console only.
#
# Local test: npm run mail:test -- --to=you@yopmail.com
# Restart API after .env changes.
# Real OTP (dev): REGISTRATION_FIXED_OTP=false and DISABLE_DEV_OTP_BYPASS=true (omit DEV_OTP_*).
# Fixed OTP (dev): REGISTRATION_FIXED_OTP=true and REGISTRATION_OTP_CODE=123456.
BREVO_API_KEY=xkeysib-your-brevo-api-key
MAIL_FROM=no-reply@bharatcaterhub.com
# Logo in OTP email loads from APP_PUBLIC_URL/brand/… (override with full URL if needed)
# EMAIL_LOGO_URL=https://bharatcaterhub.com/brand/bharat-cater-hub-logo-email.svg
MAIL_FROM_NAME="Bharat Cater Hub"
CONTACT_EMAIL=no-reply@bharatcaterhub.com

# Optional: fixed OTP only for one disposable inbox (when REGISTRATION_FIXED_OTP=false).
# DEV_OTP_EMAIL=test123@yopmail.com
# DEV_OTP_CODE=123456

# --- Real OTP (recommended for email template testing) ---
# REGISTRATION_FIXED_OTP=false
# DISABLE_DEV_OTP_BYPASS=true

# --- Fixed OTP for every signup (quick local testing) ---
REGISTRATION_FIXED_OTP=true
REGISTRATION_OTP_CODE=123456
DISABLE_DEV_OTP_BYPASS=false
DEV_OTP_CODE=123456

# If .env has NODE_ENV=production but you are on localhost, either remove it or set:
# ALLOW_FIXED_OTP_IN_PRODUCTION=true
# (staging only — never enable on real production)

# Shown in OTP email as workspace host: {subdomain}.{SUBDOMAIN_PARENT_DOMAIN}
# SUBDOMAIN_PARENT_DOMAIN=catering.test

# NODE_ENV=production

# First platform admin — run on each environment after migrations:
#   cd catering-backend && npm run seed:admin
# Use --reset to update password if the user already exists:
#   npm run seed:admin -- --reset
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_FULL_NAME=Platform Admin
# ADMIN_SEED_RESET=true
# Comma-separated browser origins allowed to call this API (scheme + host + port, no path)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://bharatcaterhub.com,https://www.bharatcaterhub.com,https://staging.bharatcaterhub.com

# Auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# MySQL — create database `catering` once (see scripts/db-create.sql or npm run db:create)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=catering

# Optional: log SQL when running TypeORM CLI migrations
TYPEORM_LOGGING=false
