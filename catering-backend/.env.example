PORT=4000

# Base URL of this API — used in uploaded image URLs (`{UPLOAD_PUBLIC_BASE_URL}/uploads/...`)
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000

# Optional: absolute path where uploaded files are written (default: ./storage/public)
# UPLOAD_DISK_ROOT=C:\\path\\to\\catering-backend\\storage\\public

# Public URL of the Next.js app (legacy magic-link path still supported)
APP_PUBLIC_URL=http://localhost:3000

# Fixed 6-digit OTP for this email (disposable inbox testing, e.g. yopmail).
# Leave blank or omit to use defaults below. Empty values like DEV_OTP_EMAIL= broke matching before.
DEV_OTP_EMAIL=test123@yopmail.com
DEV_OTP_CODE=123456

# Same OTP for every signup (testing). Truthy: true, 1, yes, on (any case). Code: REGISTRATION_OTP_CODE.
REGISTRATION_FIXED_OTP=true
REGISTRATION_OTP_CODE=123456

# In non-production, verify-otp also accepts the codes above even if REGISTRATION_FIXED_OTP failed to parse (e.g. CRLF). Set to disable:
# DISABLE_DEV_OTP_BYPASS=true

# If .env has NODE_ENV=production but you are on localhost, either remove it or set:
# ALLOW_FIXED_OTP_IN_PRODUCTION=true
# (staging only — never enable on real production)

# Shown in OTP email as workspace host: {subdomain}.{SUBDOMAIN_PARENT_DOMAIN}
# SUBDOMAIN_PARENT_DOMAIN=catering.test

# NODE_ENV=production

# First platform admin (run: npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_FULL_NAME=Platform Admin
# Comma-separated origins for the Next.js app
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# MySQL — create database `catering` once (see scripts/db-create.sql or npm run db:create)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=catering

# Optional: log SQL when running TypeORM CLI migrations
TYPEORM_LOGGING=false
