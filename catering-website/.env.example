# Copy to `.env`. Change values per environment; run `next build` after editing NEXT_PUBLIC_*.

PORT=7002

# Must match the deployed API origin (rebuild Next.js after changing).
NEXT_PUBLIC_CATERING_API_URL=http://localhost:4000
# Production: NEXT_PUBLIC_CATERING_API_URL=https://bharatcaterhub.com
# Staging: NEXT_PUBLIC_CATERING_API_URL=https://staging.bharatcaterhub.com
NEXT_PUBLIC_SITE_URL=http://localhost:7002
# Production: NEXT_PUBLIC_SITE_URL=https://bharatcaterhub.com
# Staging: NEXT_PUBLIC_SITE_URL=https://staging.bharatcaterhub.com

NEXT_PUBLIC_SITE_NAME=Bharat Cater Hub
NEXT_PUBLIC_SEO_DESCRIPTION=Find the best catering service providers near you. India's trusted catering directory with 10,000+ happy customers.
NEXT_PUBLIC_OG_IMAGE_PATH=/favicon.svg

# Local dev — show hint on /verify-otp (match backend REGISTRATION_OTP_CODE)
NEXT_PUBLIC_DEV_OTP_CODE=123456

NEXT_PUBLIC_CONTACT_EMAIL=hello@bharatcaterhub.com
NEXT_PUBLIC_SUPPORT_PHONE_DISPLAY=+91 0123456789
NEXT_PUBLIC_SUPPORT_PHONE_TEL=+910123456789
NEXT_PUBLIC_CONTACT_ADDRESS_LINE1=123 Catering Hub, Food Street,
NEXT_PUBLIC_CONTACT_ADDRESS_LINE2=Mumbai, Maharashtra 400001

# Social profile URLs (footer icons)
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/share/1Ayq9KK91G/?mibextid=wwXIfr
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/bharatcaterhub/

# Workspace onboarding + profile (Google Places address picker).
# Google Cloud → APIs & Services → ENABLE:
#   - Maps JavaScript API
#   - Places API (New)   ← required for address search (new GCP projects)
#   - Geocoding API      ← reverse geocode when dragging the map pin
# Optional legacy: Places API (only if you use old Autocomplete elsewhere).
# Credentials → your key → API restrictions → allow Maps JavaScript API, Places API (New), Geocoding API.
# Application restrictions → HTTP referrers → http://localhost:3000/* and http://localhost:7002/*
# Billing must be enabled on the project.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# NEXT_PUBLIC_SUBDOMAIN_PARENT_DOMAIN=catering.test

# next/image + resolveCateringImageDisplayUrl — must match backend S3_PUBLIC_BASE_URL host.
# Defaults in next.config include cdn.caterersspace.com and cdn.bharatcaterhub.com.
# Staging/Production: NEXT_PUBLIC_IMAGE_CDN_HOSTNAME=cdn.bharatcaterhub.com
# NEXT_PUBLIC_IMAGE_CDN_BASE_URL=https://cdn.bharatcaterhub.com
